<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Microphone access under the hardened runtime (click-to-talk dictation). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- NOTE: App Sandbox is intentionally NOT enabled. The Carbon global hotkey
	     (system-wide ⌘⇧K) requires the sandbox to be off. -->
</dict>
</plist>
