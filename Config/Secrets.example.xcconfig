// Atlas — secrets template. COMMITTED for reference only (no real values here).
//
// Setup:
//   1. cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//   2. Fill in the values from .env.local (GOOGLE_OAUTH_CLIENT_ID / _SECRET).
//   3. Config/Secrets.xcconfig is gitignored — it never gets committed.
//
// project.yml wires this file in via `configFiles:` and projects the two values
// into the generated Info.plist (INFOPLIST_KEY_GoogleOAuthClientID / _Secret),
// which GoogleOAuthConfig reads at runtime via Bundle.main.
//
// If Config/Secrets.xcconfig is absent, Xcode treats the base config as empty
// (a warning, not an error) and the Google integration stays unconfigured.
GOOGLE_OAUTH_CLIENT_ID =
GOOGLE_OAUTH_CLIENT_SECRET =

// Google Picker browser credentials for the in-app Drive import picker
// (DrivePickerSheet): the Picker browser API key and the GCP project number —
// public by design, same GCP project as the OAuth client above.
DRIVE_PICKER_API_KEY =
DRIVE_PICKER_APP_ID =

// Your Apple developer team id — per developer, so it is NOT hardcoded in
// project.yml. A free Apple ID works for local builds: Xcode → Settings →
// Accounts → add your Apple ID, then copy the Team ID of your Personal Team
// (Xcode → Settings → Accounts → select team → Team ID, or leave this empty
// and pick the team once in Signing & Capabilities after each regen).
DEVELOPMENT_TEAM =
